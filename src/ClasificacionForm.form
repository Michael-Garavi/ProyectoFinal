<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="ClasificacionForm">
  <grid id="27dc6" binding="panelPrincipal" layout-manager="GridLayoutManager" row-count="7" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="0" left="0" bottom="0" right="0"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="73944" class="javax.swing.JLabel" binding="lblTitulo">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="CLASIFICACIÓN Y PRIORIZACIÓN DE TICKETS"/>
        </properties>
      </component>
      <vspacer id="c6a2e">
        <constraints>
          <grid row="6" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
        </constraints>
      </vspacer>
      <component id="7883b" class="javax.swing.JLabel" binding="lblTipoSoporte">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Tipo de soporte:"/>
        </properties>
      </component>
      <component id="912b7" class="javax.swing.JComboBox" binding="cmbTipoSoporte">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="2" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <model>
            <item value="SELECCIONE"/>
            <item value="TECNICO"/>
            <item value="SOPORTE"/>
            <item value="OPERATIVO"/>
            <item value="CONOCIMIENTO"/>
          </model>
        </properties>
      </component>
      <component id="9e41c" class="javax.swing.JButton" binding="btnClasificar">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Clasificar Ticket"/>
        </properties>
      </component>
      <component id="ef03a" class="javax.swing.JTextArea" binding="txtResumen">
        <constraints>
          <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="6" anchor="0" fill="3" indent="0" use-parent-layout="false">
            <preferred-size width="150" height="50"/>
